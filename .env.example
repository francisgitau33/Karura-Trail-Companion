# Vercel-managed Neon Postgres
DATABASE_URL=
# Used to encrypt admin session cookies. Must be 32+ characters long.
ADMIN_SESSION_SECRET=
# First admin setup credentials
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=

# Persistent Rate Limiting (Upstash Redis)
# Required for production safety. Public suggestions will 503 if enabled without these.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
